# ===== API keys (đừng để comment cùng dòng với giá trị - python-dotenv sẽ đọc cả comment làm key) =====
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# https://console.groq.com/keys
GROQ_API_KEY=
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Model dùng để format issue + transcribe (Gemini)
GEMINI_MODEL=gemini-2.5-flash
GROQ_WHISPER_MODEL=whisper-large-v3
OPENAI_MODEL=gpt-4o
OPENAI_WHISPER_MODEL=whisper-1

# ===== OBS WebSocket (OBS > Tools > WebSocket Server Settings) =====
OBS_HOST=localhost
OBS_PORT=4455
OBS_PASSWORD=

# ===== Recording =====
# Hotkey đánh dấu bug (pynput format). record/capture = MỞ BUG MỚI; append = THÊM ẢNH vào bug đang mở.
RECORD_HOTKEY=ctrl+shift+f9
CAPTURE_HOTKEY=alt+b
APPEND_HOTKEY=alt+a
# Stream audio index của track MIC trong clip (0-based).
# OBS multitrack: track 1 = a:0, track 2 = a:1 ...
MIC_AUDIO_STREAM=0

# Record clip = PRE giây trước + POST giây sau lúc nhấn (capture chỉ lấy 1 frame).
# ⚠️ OBS Maximum Replay Time phải >= PRE+POST (mặc định 20+20 → đặt OBS = 40s).
RECORD_PRE_SECONDS=20
RECORD_POST_SECONDS=20

# ===== Jira (để trống = mock mode, issue ghi ra file JSON) =====
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
