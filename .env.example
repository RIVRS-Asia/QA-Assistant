# ===== API keys =====
GEMINI_API_KEY=          # https://aistudio.google.com/apikey
GROQ_API_KEY=            # https://console.groq.com/keys
OPENAI_API_KEY=          # https://platform.openai.com/api-keys

# Model dùng để format issue + transcribe (Gemini)
GEMINI_MODEL=gemini-2.5-flash
GROQ_WHISPER_MODEL=whisper-large-v3
OPENAI_MODEL=gpt-4o
OPENAI_WHISPER_MODEL=whisper-1

# ===== OBS WebSocket (OBS > Tools > WebSocket Server Settings) =====
OBS_HOST=localhost
OBS_PORT=4455
OBS_PASSWORD=

# ===== Recording =====
# Hotkey đánh dấu bug (pynput format)
MARKER_HOTKEY=<ctrl>+<shift>+<f9>
# Stream audio index của track MIC trong file mkv (0-based).
# OBS multitrack: track 1 = a:0, track 2 = a:1 ...
MIC_AUDIO_STREAM=0

# ===== Pipeline =====
# Cắt clip quanh marker: lùi PRE giây, tiến POST giây
CLIP_PRE_SECONDS=30
CLIP_POST_SECONDS=10

# ===== Jira (để trống = mock mode, issue ghi ra file JSON) =====
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
